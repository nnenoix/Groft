{
  "permissions": {
    "allow": ["Bash(*)", "Read(*)", "Write(*)", "Edit(*)"]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /mnt/d/orchkerstr/scripts/hooks/session_start_memory_banner.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /mnt/d/orchkerstr/scripts/hooks/user_prompt_correction_nudge.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /mnt/d/orchkerstr/scripts/hooks/pre_tool_use_destructive_block.py"
          },
          {
            "type": "command",
            "command": "python3 /mnt/d/orchkerstr/scripts/hooks/pre_tool_use_tests_before_commit.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit|mcp__claudeorch-comms__set_plan|mcp__claudeorch-comms__advance_step",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /mnt/d/orchkerstr/scripts/hooks/post_tool_use_plan_nudge.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /mnt/d/orchkerstr/scripts/hooks/stop_grounding_check.py"
          }
        ]
      }
    ]
  }
}
